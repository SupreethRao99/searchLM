# Git files - CRITICAL: Modal doesn't allow .git modifications during build
.git/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter notebooks (use Modal Notebooks if needed)
.ipynb_checkpoints/

# Output dir (persisted via Modal volume; see config paths.output_dir)
output/

# Large data/model files (use volumes for persistence)
*.pt
*.pth
*.bin
*.ckpt
*.safetensors

# Build artifacts
build/
dist/
*.egg-info/
