# SearchLM Environment Variables
# Copy this file to .env and fill in your values

# HuggingFace Token (required for downloading models and datasets)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Weights & Biases API Key (optional, for training metrics logging)
# Get your key from: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Optional: Custom model cache directory
# HF_HOME=/path/to/huggingface/cache

# Optional: Custom data directories (if not using config defaults)
# DATA_DIR=/path/to/data
# MODELS_DIR=/path/to/models
# INDEX_DIR=/path/to/indices
# OUTPUT_DIR=/path/to/output
